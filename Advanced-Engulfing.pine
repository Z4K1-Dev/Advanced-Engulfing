//@version=6
indicator("Bullish & Bearish Engulfing + Failure with Table", overlay=true)

// Input untuk menampilkan tabel atau tidak
showTable = input.bool(true, title="Tampilkan Tabel")

// Kondisi Bullish Engulfing
bullishEngulfing = (close > open) and (close[1] < open[1]) and (close > high[1])

// Kondisi Bearish Engulfing
bearishEngulfing = (close < open) and (close[1] > open[1]) and (close < low[1])

// Kondisi Bullish Engulfing Failure
bullishEngulfingFailure = bullishEngulfing[1] and (close < low[2])

// Kondisi Bearish Engulfing Failure
bearishEngulfingFailure = bearishEngulfing[1] and (close > high[2])

// Input options for text size dengan tambahan opsi "tiny"
tableTextSize = input.string("small", title="Table Text Size", options=["tiny", "small", "normal", "large"], group="Pengaturan Tabel")
labelTextSize = input.string("small", title="Label Text Size", options=["tiny", "small", "normal", "large"])

// Input options for colors
begColor = input.color(color.lime, title="Bullish Engulfing Color")
eegColor = input.color(color.red, title="Bearish Engulfing Color")
befColor = input.color(#008cff, title="Bullish Engulfing Failure Color")
eefColor = input.color(#a49400, title="Bearish Engulfing Failure Color")

// Fungsi untuk mendeteksi pola terakhir pada timeframe tertentu
getLastPattern() =>
    var string lastPattern = na
    if bullishEngulfing
        lastPattern := "BEG"
    else if bearishEngulfing
        lastPattern := "EEG"
    else if bullishEngulfingFailure
        lastPattern := "BEF"
    else if bearishEngulfingFailure
        lastPattern := "EEF"
    lastPattern

// Fungsi untuk mengonversi timeframe ke menit (jika diperlukan)
convertTimeframe(tf) =>
    // Jika tf adalah "M", "W", atau "D", tidak diubah
    if tf == "M" or tf == "W" or tf == "D"
        tf
    else
        len = str.length(tf)
        last_char = str.substring(tf, len - 1, len)
        // Jika last_char adalah "h", kalikan angka di depannya dengan 60
        if last_char == "h"
            num = str.tonumber(str.substring(tf, 0, len - 1))
            str.tostring(num * 60)
        // Jika last_char adalah "m", hapus karakter terakhir
        else if last_char == "m"
            str.substring(tf, 0, len - 1)
        else
            tf

// Timeframes yang ingin dianalisis (tetap menggunakan input asli untuk baris pertama tabel)
timeframesInput = input.string("M,W,D,4h,1h,30m,15m,5m,1m", title="Timeframes (pisahkan dengan koma)", group="Pengaturan Tabel")

// Memisahkan string timeframes menjadi array
tfArray = str.split(timeframesInput, ",")

// Fungsi untuk menentukan ukuran teks berdasarkan input
getTextSize(textSize) =>
    textSize == "tiny" ? size.tiny : textSize == "small" ? size.small : textSize == "normal" ? size.normal : size.large

// Membuat tabel
var table myTable = table.new(position.top_right, columns=array.size(tfArray), rows=2, bgcolor=color.new(color.black, 70), frame_color=color.gray)

if showTable
    // Baris pertama: Timeframes asli (sesuai input)
    for i = 0 to array.size(tfArray) - 1
        tf = str.trim(array.get(tfArray, i))
        table.cell(myTable, i, 0, tf, bgcolor=color.new(color.black, 70), text_color=color.white, text_size=getTextSize(tableTextSize))

    // Baris kedua: Informasi EG/EF dengan timeframe yang telah dikonversi (jika perlu)
    for i = 0 to array.size(tfArray) - 1
        tf_orig = str.trim(array.get(tfArray, i))
        // Konversi timeframe sesuai aturan
        converted_tf = convertTimeframe(tf_orig)
        lastPattern = request.security(syminfo.tickerid, converted_tf, getLastPattern())
        patternColor = lastPattern == "BEG" ? begColor : lastPattern == "EEG" ? eegColor : lastPattern == "BEF" ? befColor : lastPattern == "EEF" ? eefColor : color.gray
        table.cell(myTable, i, 1, lastPattern, bgcolor=patternColor, text_color=color.white, text_size=getTextSize(tableTextSize))

// Fungsi untuk mendapatkan warna berdasarkan pola
getColorForPattern(pattern, begColor, eegColor, befColor, eefColor) =>
    pattern == "BEG" ? begColor : pattern == "EEG" ? eegColor : pattern == "BEF" ? befColor : pattern == "EEF" ? eefColor : color.gray

// Tambahkan Label untuk Referensi Visual
if (bullishEngulfingFailure)
    label.new(bar_index, high, text="EF\nShort", style=label.style_label_lower_right, color=color.new(getColorForPattern("BEF", begColor, eegColor, befColor, eefColor), transp=0), textcolor=color.white, size=getTextSize(labelTextSize))
else if (bearishEngulfingFailure)
    label.new(bar_index, low, text="EF\nLong", style=label.style_label_upper_right, color=color.new(getColorForPattern("EEF", begColor, eegColor, befColor, eefColor), transp=0), textcolor=color.white, size=getTextSize(labelTextSize))
else if (bullishEngulfing)
    label.new(bar_index, low, text="Long", style=label.style_label_upper_right, color=color.new(getColorForPattern("BEG", begColor, eegColor, befColor, eefColor), transp=0), textcolor=color.black, size=getTextSize(labelTextSize))
else if (bearishEngulfing)
    label.new(bar_index, high, text="Short", style=label.style_label_lower_right, color=color.new(getColorForPattern("EEG", begColor, eegColor, befColor, eefColor), transp=0), textcolor=color.white, size=getTextSize(labelTextSize))
